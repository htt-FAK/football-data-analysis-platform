# =====================
# 数据库配置 (MySQL)
# =====================
DB_HOST=your_mysql_host
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_password_here
DB_NAME=your_db_name

# =====================
# HDFS 配置
# =====================
HDFS_HOST=localhost
HDFS_PORT=9870
HDFS_USER=root

# =====================
# FastAPI 配置
# =====================
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=True

# =====================
# Redis 配置
# =====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# =====================
# WebSocket 配置
# =====================
WS_HEARTBEAT_INTERVAL=25
WS_LIVE_POLL_INTERVAL=30
REDIS_LIVE_TTL=300

# =====================
# 爬虫配置
# =====================
CRAWL_DELAY_MIN=2
CRAWL_DELAY_MAX=5
LIVE_CRAWL_INTERVAL=30

# =====================
# Excel 导出配置
# =====================
EXPORT_DIR=./export
EXPORT_CRON=0 2 * * *
EXPORT_INCLUDE_ANOMALY=True
EXPORT_INCLUDE_COMPARISON=True

# =====================
# API-Football 配置（可选）
# =====================
API_FOOTBALL_KEY=your_api_key_here
API_FOOTBALL_BASE=https://v3.football.api-sports.io

# =====================
# AI 预测配置（阶跃星辰 + DeepSeek）
# =====================
ENABLE_AI_PREDICTION=True
STEPFUN_API_KEY=your_stepfun_api_key_here
STEPFUN_BASE_URL=https://api.stepfun.com/v1
STEPFUN_MODEL=step-3.7-flash
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://token.sensenova.cn/v1
DEEPSEEK_MODEL=deepseek-v4-flash
AI_REASONING_EFFORT=high
AI_PREDICTION_HOURS_BEFORE=5
AI_PREDICTION_SCAN_SECONDS=900
AI_PREDICTION_WINDOW_TOLERANCE_HOURS=0.5
AI_REQUEST_TIMEOUT=120

# =====================
# 联网搜索 API（独立于阶跃原生 web_search，作为实时情报来源）
# provider: tavily / serper / none
# =====================
WEB_SEARCH_PROVIDER=tavily
TAVILY_API_KEY=your_tavily_api_key_here
TAVILY_BASE_URL=https://api.tavily.com
SERPER_API_KEY=your_serper_api_key_here
SERPER_BASE_URL=https://google.serper.dev
WEB_SEARCH_MAX_RESULTS=6
WEB_SEARCH_TIMEOUT=20
